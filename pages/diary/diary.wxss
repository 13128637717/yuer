.diary-form,
.history-card {
  background: linear-gradient(180deg, #FFFFFF 0%, #F6F0FF 100%);
}

.diary-textarea {
  width: 100%;
  min-height: 200rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid var(--border);
  border-radius: 22rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
  transition: border-color 0.18s ease, background 0.18s ease;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: var(--primary-dark);
  margin: 8rpx 0 16rpx;
}

.image-section {
  margin-bottom: 24rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  position: relative;
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 18rpx rgba(255, 154, 139, 0.12);
  transition: transform 0.16s ease;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(255, 154, 139, 0.92);
  color: #FFF;
  font-size: 28rpx;
  text-align: center;
  line-height: 40rpx;
  border-radius: 50%;
}

.image-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed rgba(255, 154, 139, 0.42);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.68);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: transform 0.16s ease, border-color 0.16s ease;
}

.add-icon {
  font-size: 48rpx;
  color: var(--primary);
}

.add-text {
  font-size: 22rpx;
  color: var(--primary-dark);
  margin-top: 8rpx;
}

.history-item {
  padding: 24rpx 8rpx;
  border-bottom: 2rpx solid var(--border);
  border-radius: 18rpx;
}

.history-item:last-child {
  border-bottom: none;
}

.history-date {
  font-size: 26rpx;
  color: var(--primary-dark);
  font-weight: 700;
  margin-bottom: 12rpx;
}

.history-content {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.history-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.history-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 14rpx rgba(255, 154, 139, 0.1);
}
