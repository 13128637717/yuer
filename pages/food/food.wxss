.form-card,
.food-list {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF8DF 100%);
}

.amount-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.amount-input {
  flex: 1;
  min-width: 0;
}

.unit-picker {
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  white-space: nowrap;
  transition: transform 0.16s ease, border-color 0.16s ease;
}
