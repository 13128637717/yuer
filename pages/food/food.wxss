.date-picker {
  margin-bottom: 24rpx;
}

.date-display {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.date-label {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.date-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.date-arrow {
  font-size: 20rpx;
  color: var(--text-light);
  margin-left: 12rpx;
}

.form-card, .list-card {
  margin-bottom: 24rpx;
}

.picker-value {
  color: var(--text-primary);
}

.amount-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.amount-input {
  flex: 1;
  min-width: 0;
}

.unit-picker {
  background: #FAFAFA;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  white-space: nowrap;
}
