<view class="container">
  <date-picker-card recordDate="{{recordDate}}" todayDate="{{todayDate}}" bindchange="onDateChange" />

  <!-- 录入表单 -->
  <view class="form-card card {{editingIndex >= 0 ? 'is-editing' : ''}} fade-up">
    <view class="section-title">{{editingIndex >= 0 ? '编辑奶量' : '添加奶量'}}</view>
    <view wx:if="{{editingIndex >= 0}}" class="edit-tip">正在调整这条奶量记录，保存后会更新列表</view>
    <view class="form-group">
      <text class="form-label">时间</text>
      <time-picker value="{{formTime}}" bindchange="onTimeChange" />
    </view>
    <view class="form-group">
      <text class="form-label">奶量 (ml)</text>
      <view class="form-input-wrap">
        <input class="form-input-field" type="number" placeholder="请输入奶量" value="{{formAmount}}" bindinput="onAmountInput" />
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">类型</text>
      <picker range="{{typeOptions}}" range-key="label" value="{{formTypeIndex}}" bindchange="onTypeChange">
        <view class="form-input picker-value">{{typeOptions[formTypeIndex].label}}</view>
      </picker>
    </view>
    <view wx:if="{{recentPref && editingIndex < 0}}" class="recent-pref" hover-class="pressable-hover" bindtap="applyRecentPref">
      <text>复用上次：{{recentPref.amount}}ml · {{recentPref.type === 'breast' ? '母乳' : '配方奶'}}</text>
    </view>
    <button class="btn-primary" hover-class="button-hover" bindtap="addOrUpdate">{{editingIndex >= 0 ? '更新奶量' : '添加奶量'}}</button>
  </view>

  <!-- 当天列表 -->
  <view class="list-card card milk-list fade-up">
    <view class="section-title">{{isToday ? '今日' : recordDate}}记录 ({{milkRecords.length}})</view>
    <view wx:if="{{milkRecords.length === 0}}" class="empty-state">
      <image class="empty-img" src="/images/illustrations/empty-record.png" mode="aspectFit" />
      <text class="empty-title">还没有奶量记录</text>
      <text class="empty-desc">添加第一条，宝宝今天的补给就有迹可循啦</text>
    </view>
    <view wx:for="{{milkRecords}}" wx:key="index" class="list-item" hover-class="list-item-hover">
      <view class="list-item-left">
        <view class="list-item-title">🍼 {{item.time}} · {{item.typeText}}</view>
        <view class="list-item-desc">{{item.amount}} ml{{item.recordedBy ? ' · ' + item.recordedBy : ''}}</view>
      </view>
      <view class="list-item-actions">
        <text class="action-btn" hover-class="pressable-hover" data-index="{{index}}" bindtap="editItem">编辑</text>
        <text class="action-btn danger" hover-class="pressable-hover" data-index="{{index}}" bindtap="deleteItem">删除</text>
      </view>
    </view>
  </view>
</view>
