<view class="container">
  <view class="date-picker card" hover-class="card-hover">
    <picker mode="date" value="{{recordDate}}" end="{{todayDate}}" bindchange="onDateChange">
      <view class="date-display">
        <text class="date-label">📅</text>
        <text class="date-value">{{recordDate}}</text>
        <text class="date-arrow">▼</text>
      </view>
    </picker>
  </view>

  <view class="form-card card {{editingIndex >= 0 ? 'is-editing' : ''}} fade-up">
    <view class="section-title">{{editingIndex >= 0 ? '编辑睡眠' : '添加睡眠'}}</view>
    <view wx:if="{{editingIndex >= 0}}" class="edit-tip">正在调整这段睡眠记录，保存后会更新列表</view>
    <view class="form-group">
      <text class="form-label">入睡时间</text>
      <time-picker value="{{formStartTime}}" bindchange="onStartTimeChange" />
    </view>
    <view class="form-group">
      <text class="form-label">起床时间</text>
      <time-picker value="{{formEndTime}}" bindchange="onEndTimeChange" />
    </view>
    <view class="duration-display" wx:if="{{formDurationText}}">
      <text class="duration-icon">🌙</text>
      <text>预计时长：{{formDurationText}}</text>
    </view>
    <button class="btn-primary" hover-class="button-hover" bindtap="addOrUpdate">{{editingIndex >= 0 ? '更新睡眠' : '添加睡眠'}}</button>
  </view>

  <view class="list-card card sleep-list fade-up">
    <view class="section-title">{{isToday ? '今日' : recordDate}}记录 ({{sleepRecords.length}})</view>
    <view wx:if="{{sleepRecords.length === 0}}" class="empty-state">
      <text class="empty-icon">😴</text>
      <text class="empty-title">还没有睡眠记录</text>
      <text class="empty-desc">记录入睡和起床时间，看看宝宝睡得香不香</text>
    </view>
    <view wx:for="{{sleepRecords}}" wx:key="index" class="list-item" hover-class="list-item-hover">
      <view class="list-item-left">
        <view class="list-item-title">😴 {{item.startTime}} - {{item.endTime}}</view>
        <view class="list-item-desc">{{item.durationText}}</view>
      </view>
      <view class="list-item-actions">
        <text class="action-btn" hover-class="pressable-hover" data-index="{{index}}" bindtap="editItem">编辑</text>
        <text class="action-btn danger" hover-class="pressable-hover" data-index="{{index}}" bindtap="deleteItem">删除</text>
      </view>
    </view>
  </view>
</view>
