.timer-card {
  margin-bottom: 24rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #F0FFF7 100%);
}

.timer-active {
  text-align: center;
}

.timer-desc {
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 24rpx;
}

.timer-start {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary-dark);
  margin: 24rpx 0 32rpx;
}

.empty-img {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 16rpx;
}

.form-card,
.sleep-list {
  background: linear-gradient(180deg, #FFFFFF 0%, #F0FFF7 100%);
}

.duration-display {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--primary-dark);
  font-weight: 700;
  margin-bottom: 24rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.78);
}

.duration-icon {
  margin-right: 10rpx;
}
