.form-card,
.sleep-list {
  background: linear-gradient(180deg, #FFFFFF 0%, #F0FFF7 100%);
}

.duration-display {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--primary-dark);
  font-weight: 700;
  margin-bottom: 24rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.78);
}

.duration-icon {
  margin-right: 10rpx;
}
