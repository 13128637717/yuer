.section {
  margin-bottom: 24rpx;
}

.milk-section {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF4F1 100%);
}

.food-section {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF8DF 100%);
}

.sleep-section {
  background: linear-gradient(180deg, #FFFFFF 0%, #F0FFF7 100%);
}

.diary-section {
  background: linear-gradient(180deg, #FFFFFF 0%, #F6F0FF 100%);
}

.poop-section {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF8EF 100%);
}

.poop-list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.poop-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-total {
  font-size: 26rpx;
  color: var(--primary-dark);
  font-weight: 700;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-light);
  padding: 20rpx 0;
  text-align: center;
}

.empty-action {
  margin-top: 32rpx;
}

.diary-preview {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  max-height: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}
