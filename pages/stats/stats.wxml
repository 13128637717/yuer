<view class="container">
  <view wx:if="{{!hasFamily}}" class="empty-state card fade-up">
    <image class="empty-img" src="/images/illustrations/empty-stats.png" mode="aspectFit" />
    <text class="empty-title">还没有家庭数据</text>
    <text class="empty-desc">创建或加入家庭后，就能看到宝宝成长趋势啦</text>
  </view>

  <block wx:else>
    <view wx:if="{{weekTrend.visible}}" class="week-trend card fade-up">
      <view class="week-trend-header">
        <view class="section-title week-trend-title">近7天趋势</view>
        <view class="week-trend-badge">截至昨日</view>
      </view>
      <view wx:if="{{weekTrend.loading}}" class="week-trend-skeleton">加载中...</view>
      <view wx:else class="week-trend-grid">
        <view class="week-trend-item milk-trend-item">
          <view class="week-trend-item-head">
            <image class="week-trend-icon" src="/images/icons/milk.png" mode="aspectFit" />
            <text class="week-trend-label">日均奶量</text>
          </view>
          <view class="week-trend-value">
            <text class="stat-number">{{weekTrend.avgMilk}}</text>
            <text class="stat-unit">ml</text>
          </view>
          <view class="week-trend-change">
            <text class="week-trend-change-label">较上周</text>
            <text class="change-badge change-{{weekTrend.milkChangeDir}}">{{weekTrend.milkChange}}</text>
          </view>
        </view>
        <view class="week-trend-item sleep-trend-item">
          <view class="week-trend-item-head">
            <image class="week-trend-icon" src="/images/icons/sleep.png" mode="aspectFit" />
            <text class="week-trend-label">日均睡眠</text>
          </view>
          <view class="week-trend-value">
            <text class="stat-number">{{weekTrend.avgSleepH}}</text>
            <text class="stat-unit">小时</text>
          </view>
          <view class="week-trend-change">
            <text class="week-trend-change-label">较上周</text>
            <text class="change-badge change-{{weekTrend.sleepChangeDir}}">{{weekTrend.sleepChange}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="tabs card pill-tabs">
      <view class="tab-item pill-tab {{days === 7 ? 'active' : ''}}" data-days="7" hover-class="pressable-hover" bindtap="switchDays">最近7天</view>
      <view class="tab-item pill-tab {{days === 30 ? 'active' : ''}}" data-days="30" hover-class="pressable-hover" bindtap="switchDays">最近30天</view>
    </view>

    <view class="chart-card card milk-chart fade-up {{loading ? 'is-loading' : ''}}" hover-class="card-hover">
      <view class="chart-title">🍼 奶量趋势 (母乳/配方奶/总量)</view>
      <view class="chart-container">
        <view wx:if="{{loading}}" class="chart-skeleton">加载中...</view>
        <ec-canvas id="milkChart" canvas-id="milkChart" ec="{{ecMilk}}"></ec-canvas>
      </view>
    </view>

    <!-- 辅食趋势图 -->
    <view class="chart-card card food-chart fade-up {{loading ? 'is-loading' : ''}}" hover-class="card-hover">
      <view class="chart-title">🥣 辅食趋势 (g / ml)</view>
      <view class="chart-container">
        <view wx:if="{{loading}}" class="chart-skeleton">加载中...</view>
        <ec-canvas id="foodChart" canvas-id="foodChart" ec="{{ecFood}}"></ec-canvas>
      </view>
    </view>

    <!-- 睡眠趋势图 -->
    <view class="chart-card card sleep-chart fade-up {{loading ? 'is-loading' : ''}}" hover-class="card-hover">
      <view class="chart-title">😴 睡眠趋势 (小时)</view>
      <view class="chart-container">
        <view wx:if="{{loading}}" class="chart-skeleton">加载中...</view>
        <ec-canvas id="sleepChart" canvas-id="sleepChart" ec="{{ecSleep}}"></ec-canvas>
      </view>
    </view>

    <!-- 拉粑粑次数趋势图 -->
    <view class="chart-card card poop-chart fade-up {{loading ? 'is-loading' : ''}}" hover-class="card-hover">
      <view class="chart-title">💩 拉粑粑次数</view>
      <view class="chart-container">
        <view wx:if="{{loading}}" class="chart-skeleton">加载中...</view>
        <ec-canvas id="poopChart" canvas-id="poopChart" ec="{{ecPoop}}"></ec-canvas>
      </view>
    </view>

    <view wx:if="{{loading}}" class="loading-hint">正在整理宝宝成长曲线...</view>

    <!-- 导出记录 -->
    <view class="export-section card fade-up">
      <button class="btn-secondary share-card-btn" hover-class="button-hover" bindtap="shareDailyCard" disabled="{{shareLoading}}">{{shareLoading ? '生成中...' : '生成今日分享图'}}</button>
      <button wx:if="{{!showExport}}" class="btn-primary btn-stack-gap" hover-class="button-hover" bindtap="openExport">导出记录</button>
      <block wx:if="{{showExport}}">
        <view class="section-title">📤 导出记录</view>
        <view class="export-tabs pill-tabs">
          <view class="export-tab pill-tab {{exportRange === 'week' ? 'active' : ''}}" data-range="week" hover-class="pressable-hover" bindtap="switchExportRange">最近7天</view>
          <view class="export-tab pill-tab {{exportRange === 'month' ? 'active' : ''}}" data-range="month" hover-class="pressable-hover" bindtap="switchExportRange">最近30天</view>
          <view class="export-tab pill-tab {{exportRange === 'all' ? 'active' : ''}}" data-range="all" hover-class="pressable-hover" bindtap="switchExportRange">全部记录</view>
        </view>
        <scroll-view class="export-text-wrap" scroll-y="{{true}}">
          <view class="export-text" user-select>{{exportLoading ? (exportProgress || '加载中...') : exportText}}</view>
        </scroll-view>
        <button class="btn-primary btn-stack-gap" hover-class="button-hover" bindtap="copyExportText" disabled="{{exportLoading || !exportText}}">复制到剪贴板</button>
      </block>
    </view>
  </block>

  <canvas type="2d" id="shareCanvas" class="share-canvas"></canvas>
</view>