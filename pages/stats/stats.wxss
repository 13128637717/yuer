.tabs {
  margin-bottom: 24rpx;
}

.tab-item {
  font-size: 28rpx;
}

.tab-item.active {
  color: var(--primary-dark);
}

.chart-card {
  margin-bottom: 24rpx;
  padding-bottom: 22rpx;
}

.milk-chart {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF4F1 100%);
}

.food-chart {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF8DF 100%);
}

.sleep-chart {
  background: linear-gradient(180deg, #FFFFFF 0%, #F0FFF7 100%);
}

.chart-title {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 18rpx;
}

.chart-container {
  width: 100%;
  height: 400rpx;
}

ec-canvas {
  width: 100%;
  height: 100%;
}

.loading-hint {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-light);
  padding: 20rpx;
  animation: fadeUp 0.3s ease-out both;
}

.export-section {
  margin-bottom: 24rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #F6F0FF 100%);
}

.export-tabs {
  margin-bottom: 16rpx;
}

.export-tab {
  font-size: 24rpx;
}

.export-text-wrap {
  height: 400rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(255, 184, 173, 0.22);
  border-radius: 22rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.export-text {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}