.tabs {
  display: flex;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--text-light);
  border-radius: 16rpx;
  transition: all 0.2s;
}

.tab-item.active {
  background: var(--primary);
  color: #FFFFFF;
  font-weight: 500;
}

.chart-card {
  margin-bottom: 24rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.chart-container {
  width: 100%;
  height: 400rpx;
}

ec-canvas {
  width: 100%;
  height: 100%;
}

.loading-hint {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-light);
  padding: 16rpx;
}

.export-section {
  margin-bottom: 24rpx;
}

.export-tabs {
  display: flex;
  padding: 8rpx;
  margin-bottom: 16rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
}

.export-tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: var(--text-light);
  border-radius: 12rpx;
}

.export-tab.active {
  background: var(--primary);
  color: #FFFFFF;
  font-weight: 500;
}

.export-text-wrap {
  height: 400rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.export-text {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}