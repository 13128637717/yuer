.week-trend {
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF0EA 56%, #FFE1EA 100%);
}

.week-trend-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.week-trend-title {
  margin-bottom: 0;
}

.week-trend-badge {
  font-size: 22rpx;
  color: var(--text-secondary);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  white-space: nowrap;
}

.week-trend-skeleton {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 160rpx;
  font-size: 26rpx;
  color: var(--text-light);
  background: rgba(255, 255, 255, 0.55);
  border-radius: 22rpx;
}

.week-trend-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.week-trend-item {
  padding: 24rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(255, 184, 173, 0.16);
  box-sizing: border-box;
}

.milk-trend-item {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, #FFF4F1 100%);
}

.sleep-trend-item {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, #F0FFF7 100%);
}

.week-trend-item-head {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.week-trend-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.week-trend-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.week-trend-value {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.week-trend-item .stat-number {
  font-size: 44rpx;
}

.week-trend-change {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.week-trend-change-label {
  font-size: 22rpx;
  color: var(--text-light);
}

.change-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  line-height: 1.4;
}

.change-up {
  color: #3D9A72;
  background: rgba(126, 200, 163, 0.22);
}

.change-down {
  color: var(--primary-dark);
  background: rgba(255, 154, 139, 0.18);
}

.change-flat {
  color: var(--text-light);
  background: rgba(153, 153, 153, 0.12);
}

.change-new {
  color: #5B8FD9;
  background: rgba(142, 197, 255, 0.22);
}

.chart-skeleton {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--text-light);
  background: rgba(255, 255, 255, 0.72);
  z-index: 2;
}

.chart-card.is-loading .chart-container {
  position: relative;
}

.tabs {
  margin-bottom: 24rpx;
}

.tab-item {
  font-size: 28rpx;
}

.tab-item.active {
  color: var(--primary-dark);
}

.chart-card {
  margin-bottom: 24rpx;
  padding-bottom: 22rpx;
}

.milk-chart {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF4F1 100%);
}

.food-chart {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF8DF 100%);
}

.sleep-chart {
  background: linear-gradient(180deg, #FFFFFF 0%, #F0FFF7 100%);
}

.poop-chart {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF8EF 100%);
}

.chart-title {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 18rpx;
}

.chart-container {
  width: 100%;
  height: 400rpx;
}

ec-canvas {
  width: 100%;
  height: 100%;
}

.loading-hint {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-light);
  padding: 20rpx;
  animation: fadeUp 0.3s ease-out both;
}

.export-section {
  margin-bottom: 24rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #F6F0FF 100%);
}

.export-tabs {
  margin-bottom: 16rpx;
}

.export-tab {
  font-size: 24rpx;
}

.export-text-wrap {
  height: 400rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(255, 184, 173, 0.22);
  border-radius: 22rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.export-text {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.share-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 600px;
  height: 800px;
}