<view class="container">
  <date-picker-card
    recordDate="{{recordDate}}"
    todayDate="{{todayDate}}"
    bindchange="onDateChange"
  />

  <view class="form-card card {{editingIndex >= 0 ? 'is-editing' : ''}} fade-up">
    <view class="section-title">{{editingIndex >= 0 ? '编辑记录' : '添加记录'}}</view>
    <view wx:if="{{editingIndex >= 0}}" class="edit-tip">正在调整这条记录，保存后会更新列表</view>
    <view class="form-group">
      <text class="form-label">时间</text>
      <time-picker value="{{formTime}}" bindchange="onTimeChange" />
    </view>
    <view class="form-group">
      <text class="form-label">状态</text>
      <picker range="{{statusOptions}}" range-key="label" value="{{formStatusIndex}}" bindchange="onStatusChange">
        <view class="form-input picker-value">{{statusOptions[formStatusIndex].label}}</view>
      </picker>
    </view>
    <view class="form-group">
      <text class="form-label">状态图片（选填）</text>
      <image-uploader
        maxCount="{{1}}"
        fileIds="{{formImage ? [formImage] : []}}"
        imageUrls="{{formImageUrl ? [formImageUrl] : []}}"
        cloudPathPrefix="poop/{{familyId}}/{{recordDate}}"
        bindchange="onImageUploaderChange"
      />
    </view>
    <button class="btn-primary" hover-class="button-hover" bindtap="addOrUpdate" disabled="{{uploading}}">{{editingIndex >= 0 ? '更新记录' : '添加记录'}}</button>
  </view>

  <view class="list-card card poop-list fade-up">
    <view class="section-title">{{isToday ? '今日' : recordDate}}记录 ({{poopRecords.length}})</view>
    <view wx:if="{{poopRecords.length === 0}}" class="empty-state">
      <image class="empty-img" src="/images/illustrations/empty-record.png" mode="aspectFit" />
      <text class="empty-title">还没有拉粑粑记录</text>
      <text class="empty-desc">添加第一条，方便追踪宝宝排便情况</text>
    </view>
    <view wx:for="{{poopRecords}}" wx:key="index" class="list-item" hover-class="list-item-hover">
      <view class="list-item-row">
        <view class="list-item-left">
          <view class="list-item-title">💩 {{item.time}} · {{item.statusText}}</view>
          <view class="list-item-desc">{{item.recordedBy ? item.recordedBy : ''}}{{item.recordedBy && item.imageUrl ? ' · ' : ''}}{{item.imageUrl ? '已附状态图' : ''}}</view>
        </view>
        <image
          wx:if="{{item.imageUrl}}"
          class="list-thumb"
          src="{{item.imageUrl}}"
          mode="aspectFill"
          data-url="{{item.imageUrl}}"
          bindtap="previewItemImage"
        />
      </view>
      <view class="list-item-actions">
        <text class="action-btn" hover-class="pressable-hover" data-index="{{index}}" bindtap="editItem">编辑</text>
        <text class="action-btn danger" hover-class="pressable-hover" data-index="{{index}}" bindtap="deleteItem">删除</text>
      </view>
    </view>
  </view>
</view>
