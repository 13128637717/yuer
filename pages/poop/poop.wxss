.form-card,
.poop-list {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF8EF 100%);
}

.image-section {
  margin-bottom: 8rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  position: relative;
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 18rpx rgba(255, 154, 139, 0.12);
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(255, 154, 139, 0.92);
  color: #FFF;
  font-size: 28rpx;
  text-align: center;
  line-height: 40rpx;
  border-radius: 50%;
}

.image-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed rgba(255, 154, 139, 0.42);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.68);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: var(--primary);
}

.add-text {
  font-size: 22rpx;
  color: var(--primary-dark);
  margin-top: 8rpx;
}

.list-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.list-item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex: 1;
}
