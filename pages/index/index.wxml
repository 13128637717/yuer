<view class="container">

  <view wx:if="{{!hasFamily}}" class="no-family card fade-up">

    <image class="no-family-img" src="/images/illustrations/welcome.png" mode="aspectFit" />

    <view class="no-family-title">欢迎使用宝宝成长助手</view>

    <view class="no-family-desc">请先创建或加入家庭，开始记录宝宝成长</view>

    <button class="btn-primary" hover-class="button-hover" bindtap="goFamily">去创建/加入家庭</button>

  </view>



  <block wx:else>

    <view class="baby-card card fade-up" hover-class="card-hover">

      <view class="baby-info">

        <image class="baby-avatar-img" src="{{babyAvatarUrl}}" mode="aspectFill" />

        <view class="baby-detail">

          <view class="baby-name">{{babyName}}</view>

          <view class="baby-age">{{monthAge}}</view>

        </view>

      </view>

      <view class="family-link" hover-class="pressable-hover" bindtap="goFamily">

        <text>家庭管理</text>

        <text class="arrow">›</text>

      </view>

    </view>



    <view wx:if="{{yesterdayHint}}" class="yesterday-hint card fade-up" hover-class="card-hover" bindtap="goRecordsYesterday">
      <text class="yesterday-hint-text">{{yesterdayHint}}</text>
      <text class="yesterday-hint-arrow">去补记 ›</text>
    </view>



    <view class="section-title">今日概况</view>

    <view class="stats-grid">

      <view class="stat-card card milk-stat" hover-class="card-hover">

        <image class="stat-icon" src="/images/icons/milk.png" mode="aspectFit" />

        <view class="stat-label">奶量</view>

        <view class="stat-value">

          <text class="stat-number">{{totalMilk}}</text>

          <text class="stat-unit">ml</text>

        </view>

      </view>

      <view class="stat-card card food-stat" hover-class="card-hover">

        <image class="stat-icon" src="/images/icons/food.png" mode="aspectFit" />

        <view class="stat-label">辅食</view>

        <view class="stat-value">

          <text class="stat-number">{{foodStatValue}}</text>

          <text class="stat-unit">{{foodStatUnit}}</text>

        </view>

      </view>

      <view class="stat-card card sleep-stat" hover-class="card-hover">

        <image class="stat-icon" src="/images/icons/sleep.png" mode="aspectFit" />

        <view class="stat-label">睡眠</view>

        <view class="stat-value">

          <block wx:if="{{showSleepHours}}">

            <text class="stat-number">{{sleepHours}}</text>

            <text class="stat-unit">小时</text>

          </block>

          <block wx:if="{{showSleepMinutes}}">

            <text class="stat-number">{{sleepMinutes}}</text>

            <text class="stat-unit">分钟</text>

          </block>

        </view>

      </view>

      <view class="stat-card card poop-stat" hover-class="card-hover">

        <image class="stat-icon" src="/images/icons/poop.png" mode="aspectFit" />

        <view class="stat-label">拉粑粑</view>

        <view class="stat-value">

          <text class="stat-number">{{poopCount}}</text>

          <text class="stat-unit">次</text>

        </view>

      </view>

    </view>



    <view class="section-title">快捷记录</view>

    <view class="quick-grid">

      <view class="quick-item card milk fade-up" hover-class="card-hover" bindtap="goMilk">

        <view class="quick-icon-wrap">

          <image class="quick-icon-img" src="/images/icons/milk.png" mode="aspectFit" />

        </view>

        <view class="quick-text">记奶量</view>

      </view>

      <view class="quick-item card food fade-up" hover-class="card-hover" bindtap="goFood">

        <view class="quick-icon-wrap">

          <image class="quick-icon-img" src="/images/icons/food.png" mode="aspectFit" />

        </view>

        <view class="quick-text">记辅食</view>

      </view>

      <view class="quick-item card sleep fade-up" hover-class="card-hover" bindtap="goSleep">

        <view class="quick-icon-wrap">

          <image class="quick-icon-img" src="/images/icons/sleep.png" mode="aspectFit" />

        </view>

        <view class="quick-text">记睡眠</view>

      </view>

      <view class="quick-item card poop fade-up" hover-class="card-hover" bindtap="goPoop">

        <view class="quick-icon-wrap">

          <image class="quick-icon-img" src="/images/icons/poop.png" mode="aspectFit" />

        </view>

        <view class="quick-text">记拉粑粑</view>

      </view>

      <view class="quick-item card diary fade-up" hover-class="card-hover" bindtap="goDiary">

        <view class="quick-icon-wrap">

          <image class="quick-icon-img" src="/images/icons/diary.png" mode="aspectFit" />

        </view>

        <view class="quick-text">写心得</view>

      </view>

    </view>



    <view wx:if="{{timeline.length > 0}}" class="timeline-section">
      <view class="section-title">今日时间线</view>
      <view class="timeline-panel card">
        <view class="timeline-list">
          <view
            wx:for="{{timeline}}"
            wx:key="key"
            class="timeline-item timeline-{{item.type}} fade-up"
            style="--item-index: {{index}}"
          >
            <view class="timeline-time-col">
              <text class="timeline-time">{{item.time}}</text>
            </view>
            <view class="timeline-axis-col">
              <view class="timeline-dot"></view>
              <view wx:if="{{index < timeline.length - 1}}" class="timeline-line"></view>
            </view>
            <view class="timeline-card">
              <view class="timeline-card-row">
                <view class="timeline-icon-wrap">
                  <image class="timeline-icon-img" src="{{item.iconSrc}}" mode="aspectFit" />
                </view>
                <view class="timeline-info">
                  <view class="timeline-title-row">
                    <text class="timeline-label">{{item.label}}</text>
                    <text class="timeline-detail">{{item.detail}}</text>
                    <text wx:if="{{item.timeRange}}" class="timeline-time-range">{{item.timeRange}}</text>
                  </view>
                  <view wx:if="{{item.subDetail}}" class="timeline-meta">{{item.subDetail}}</view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

  </block>

</view>
