.no-family {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.no-family-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.no-family-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.no-family-desc {
  font-size: 28rpx;
  color: var(--text-light);
  margin-bottom: 48rpx;
  text-align: center;
}

.baby-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.baby-info {
  display: flex;
  align-items: center;
}

.baby-avatar {
  font-size: 80rpx;
  margin-right: 24rpx;
}

.baby-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.baby-age {
  font-size: 26rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.family-link {
  font-size: 26rpx;
  color: var(--primary);
  display: flex;
  align-items: center;
}

.arrow {
  font-size: 32rpx;
  margin-left: 4rpx;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.stat-card {
  flex: 1;
  text-align: center;
  padding: 24rpx 16rpx;
  margin-bottom: 0;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 12rpx;
}

.stat-sleep {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx;
  margin-bottom: 0;
}

.quick-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.quick-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}
