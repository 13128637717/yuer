.no-family {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 90rpx 44rpx;
  margin-top: 80rpx;
  text-align: center;
}

.no-family-icon {
  font-size: 118rpx;
  margin-bottom: 32rpx;
  animation: floatSoft 2.8s ease-in-out infinite;
}

.no-family-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.no-family-desc {
  font-size: 28rpx;
  color: var(--text-light);
  margin-bottom: 48rpx;
  text-align: center;
}

.baby-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF0EA 56%, #FFE1EA 100%);
}

.baby-info {
  display: flex;
  align-items: center;
}

.baby-avatar {
  font-size: 56rpx;
  margin-right: 24rpx;
  animation: floatSoft 3s ease-in-out infinite;
}

.baby-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.baby-age {
  font-size: 26rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.family-link {
  font-size: 26rpx;
  color: var(--primary-dark);
  display: flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
}

.arrow {
  font-size: 32rpx;
  margin-left: 4rpx;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.stat-card {
  flex: 1;
  text-align: center;
  padding: 24rpx 16rpx;
  margin-bottom: 0;
}

.stat-card::after {
  width: 88rpx;
  height: 88rpx;
}

.milk-stat {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF4F1 100%);
}

.food-stat {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF8DF 100%);
}

.sleep-stat {
  background: linear-gradient(180deg, #FFFFFF 0%, #F0FFF7 100%);
}

.stat-emoji {
  font-size: 34rpx;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 12rpx;
}

.stat-sleep {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx;
  margin-bottom: 0;
}

.quick-item.milk {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF4F1 100%);
}

.quick-item.food {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF8DF 100%);
}

.quick-item.sleep {
  background: linear-gradient(180deg, #FFFFFF 0%, #F0FFF7 100%);
}

.quick-item.diary {
  background: linear-gradient(180deg, #FFFFFF 0%, #F6F0FF 100%);
}

.quick-icon {
  font-size: 46rpx;
  margin-bottom: 16rpx;
}

.quick-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}
