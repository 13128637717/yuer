.welcome-card {
  text-align: center;
  padding: 60rpx 32rpx;
}

.welcome-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: var(--text-light);
}

.action-btns {
  margin-top: 32rpx;
}

.form-card {
  margin-top: 24rpx;
}

.picker-value {
  color: var(--text-primary);
}

.family-info {
  margin-bottom: 24rpx;
}

.baby-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.baby-info-main {
  flex: 1;
}

.edit-btns {
  margin-bottom: 24rpx;
}

.switch-hint {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 24rpx;
}

.baby-emoji {
  font-size: 72rpx;
  margin-right: 24rpx;
}

.info-name {
  font-size: 34rpx;
  font-weight: 600;
}

.info-birth {
  font-size: 26rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.invite-section {
  margin-bottom: 24rpx;
}

.invite-desc {
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.invite-code-box {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF5F2;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
}

.invite-code-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-right: 20rpx;
}

.invite-code-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
  letter-spacing: 8rpx;
}

.invite-actions {
  display: flex;
  flex-direction: column;
}

.invite-share-btn,
.invite-copy-btn {
  margin: 0;
}

.invite-banner {
  display: flex;
  align-items: center;
  background: #FFF5F2;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.invite-banner-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.invite-banner-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--primary-dark);
  line-height: 1.5;
}

.member-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.member-item:last-child {
  border-bottom: none;
}

.wx-nick-group {
  margin-bottom: 8rpx;
}

.wx-nick-wrap {
  border-color: #FFD4CC;
}

.wx-nick-wrap.is-valid {
  border-color: var(--border);
}

.wx-nick-input {
  color: var(--text-primary);
}

.wx-nick-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--primary);
  line-height: 1.5;
}

.member-name {
  font-size: 28rpx;
  color: var(--text-primary);
}

.member-role {
  font-size: 24rpx;
  color: var(--text-light);
  margin-left: 16rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.setting-hint {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.leave-section {
  margin-top: 32rpx;
  padding-bottom: 32rpx;
}

.danger-btn {
  color: #E74C3C !important;
  border-color: #E74C3C !important;
}
