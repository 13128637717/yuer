.uploader {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.uploader.is-circular {
  justify-content: center;
}

.uploader-item,
.uploader-add {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #FFF8F4;
  border: 2rpx dashed #FFD4C8;
}

.uploader-item.is-circle,
.uploader-add.is-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: visible;
}

.uploader-img-wrap {
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.uploader-img-wrap.is-circle {
  border-radius: 50%;
}

.uploader-img {
  width: 100%;
  height: 100%;
}

.uploader-remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.45);
  color: #fff;
  font-size: 28rpx;
  border-bottom-left-radius: 12rpx;
}

.uploader-remove.is-circle {
  top: -4rpx;
  right: -4rpx;
  border-radius: 50%;
  line-height: 40rpx;
}

.uploader-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  width: 48rpx;
  height: 48rpx;
}

.add-text {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}
