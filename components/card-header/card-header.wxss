.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-icon {
  width: 36rpx;
  height: 36rpx;
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-emoji {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-total {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--primary-dark);
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
}
