.date-picker {
  margin-bottom: 0;
}

.date-display {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.date-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.date-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.date-arrow {
  font-size: 20rpx;
  color: var(--text-light);
  margin-left: 12rpx;
}
