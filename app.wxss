/* 全局样式 - 柔和育儿主题 */
page {
  --primary: #FF9A8B;
  --primary-light: #FFB8AD;
  --primary-dark: #E87A6B;
  --bg: #FFF8F0;
  --card-bg: #FFFFFF;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --border: #F0E6DE;
  --success: #7EC8A3;
  --warning: #FFD166;
  --card-shadow: 0 4rpx 20rpx rgba(255, 154, 139, 0.15);

  background-color: var(--bg);
  color: var(--text-primary);
  font-size: 28rpx;
  box-sizing: border-box;
}

.container {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--card-shadow);
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: var(--primary);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

/* 主按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  padding: 20rpx 0;
  width: 100%;
  line-height: 1.5;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

/* 次要按钮 */
.btn-secondary {
  background: #FFFFFF;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 48rpx;
  font-size: 28rpx;
  padding: 16rpx 0;
  width: 100%;
}

.btn-secondary::after {
  border: none;
}

/* 统计数字 */
.stat-number {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary);
}

.stat-unit {
  font-size: 24rpx;
  color: var(--text-light);
  margin-left: 8rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: var(--text-light);
  font-size: 28rpx;
}

/* 表单组 */
.form-group {
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

/* 选择器展示框 */
.form-input {
  width: 100%;
  min-height: 88rpx;
  line-height: 88rpx;
  background: #FAFAFA;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  display: block;
}

/* 原生 input 外层容器 */
.form-input-wrap {
  width: 100%;
  min-height: 88rpx;
  background: #FAFAFA;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.form-input-field {
  flex: 1;
  width: 100%;
  min-width: 0;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

/* 列表项 */
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-left {
  flex: 1;
}

.list-item-title {
  font-size: 28rpx;
  color: var(--text-primary);
}

.list-item-desc {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.list-item-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  color: var(--primary);
  padding: 8rpx 16rpx;
}

.action-btn.danger {
  color: #E74C3C;
}
